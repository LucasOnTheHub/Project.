{
  "name": "project-dot",
  "version": "0.9.0",
  "description": "File-based project manager with a 3D spatial interface",
  "type": "module",
  "main": "dist/electron/main.js",
  "bin": {
    "project": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "build:ui": "vite build --config vite.config.ui.ts",
    "dev:ui": "vite --config vite.config.ui.ts",
    "typecheck:ui": "tsc --project tsconfig.ui.json",
    "build:all": "npm run build && npm run build:ui",
    "electron": "electron dist/electron/main.js",
    "ui": "npm run build:all && npm run electron -- --dir .",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest",
    "start": "node dist/cli/index.js",
    "dist:win": "npm run build:all && electron-builder --win",
    "dist:mac": "npm run build:all && electron-builder --mac",
    "dist:linux": "npm run build:all && electron-builder --linux",
    "dist:all": "npm run build:all && electron-builder -mwl",
    "release": "npm run build:all && electron-builder --publish always"
  },
  "keywords": [
    "project-manager",
    "file-based",
    "3d",
    "mcp",
    "vault"
  ],
  "author": "LucasOnTheHub",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@react-three/drei": "*",
    "@react-three/fiber": "*",
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "d3": "^7.9.0",
    "gray-matter": "^4.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "simple-git": "^3.36.0",
    "three": "*"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "*",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.8",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
